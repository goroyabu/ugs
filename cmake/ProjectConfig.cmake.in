@PACKAGE_INIT@

# Example usage in CMakeLists.txt:
#   configure_package_config_file(
#     "${CMAKE_SOURCE_DIR}/cmake/ProjectConfig.cmake.in"
#     "${CMAKE_CURRENT_BINARY_DIR}/DemoAppConfig.cmake"
#     INSTALL_DESTINATION "${CMAKE_INSTALL_LIBDIR}/cmake/DemoApp"
#   )
#   # When versioning is required:
#   write_basic_package_version_file(
#     "${CMAKE_CURRENT_BINARY_DIR}/DemoAppConfigVersion.cmake"
#     VERSION "${PROJECT_VERSION}"
#     COMPATIBILITY SameMajorVersion
#   )

if(EXISTS "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_INCLUDEDIR@")
  set(@PROJECT_NAME_UPPER@_INCLUDE_DIR "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_INCLUDEDIR@")
endif()

if(NOT "@PROJECT_VERSION@" STREQUAL "")
  set(@PROJECT_NAME_UPPER@_VERSION_STRING "@PROJECT_VERSION@")
endif()

include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")

check_required_components("@PROJECT_NAME@")
